{
  "name": "rentease",
  "version": "1.0.0",
  "description": "RentEase - Furniture & Appliance Rental Platform",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "set HOST=0.0.0.0&& cd client && npm run start",
    "install-all": "npm install && cd client && npm install",
    "build": "cd client && npm run build",
    "deploy": "npm run build && npm start"
  },
  "keywords": [
    "rental",
    "furniture",
    "appliances",
    "monthly-rental",
    "platform"
  ],
  "author": "RentEase Team",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "morgan": "^1.10.0",
    "nodemailer": "^8.0.2",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
